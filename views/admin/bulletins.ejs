<div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-gray-100 dark:border-slate-700 overflow-hidden">
    <!-- Header -->
    <div class="p-6 border-b border-gray-50 dark:border-slate-700 flex justify-between items-center">
        <h3 class="font-bold text-pnp-blue dark:text-pnp-gold uppercase tracking-widest text-xs">Bulletin Board Management</h3>
        <a href="/admin/bulletins/create" class="bg-pnp-blue text-white px-6 py-2 rounded-lg text-xs font-bold uppercase tracking-widest hover:bg-blue-900 transition shadow-md">
            <i class="fas fa-plus mr-2"></i> New Bulletin
        </a>
    </div>

    <!-- Table -->
    <div class="overflow-x-auto">
        <table class="w-full text-left text-sm">
            <thead class="bg-gray-50 dark:bg-slate-900/50 text-gray-400 dark:text-gray-500 uppercase text-[10px] font-bold tracking-widest">
                <tr>
                    <th class="px-6 py-4">Title</th>
                    <th class="px-6 py-4">Category</th>
                    <th class="px-6 py-4">Date Posted</th>
                    <th class="px-6 py-4">Status</th>
                    <th class="px-6 py-4">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50 dark:divide-slate-700">
                <% bulletins.forEach(bulletin => { %>
                    <tr class="hover:bg-gray-50 dark:hover:bg-slate-700/50 transition">
                        <td class="px-6 py-4 font-bold text-pnp-blue dark:text-pnp-gold max-w-xs truncate"><%= bulletin.title %></td>
                        <td class="px-6 py-4">
                            <% 
                                const badgeColors = {
                                    'Wanted Person': 'bg-red-100 dark:bg-red-900/30 text-red-600 dark:text-red-400',
                                    'Missing Person': 'bg-orange-100 dark:bg-orange-900/30 text-orange-600 dark:text-orange-400',
                                    'Crime Advisory': 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-600 dark:text-yellow-400',
                                    'Recovered Property': 'bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-400',
                                    'General Announcement': 'bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400'
                                };
                            %>
                            <span class="px-2 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest <%= badgeColors[bulletin.category] %>">
                                <%= bulletin.category %>
                            </span>
                        </td>
                        <td class="px-6 py-4 text-gray-400 dark:text-gray-500 text-xs"><%= new Date(bulletin.created_at).toLocaleDateString() %></td>
                        <td class="px-6 py-4">
                            <% if (bulletin.is_archived) { %>
                                <span class="bg-gray-100 dark:bg-gray-700 text-gray-400 dark:text-gray-500 px-2 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Archived</span>
                            <% } else { %>
                                <span class="bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-400 px-2 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Active</span>
                            <% } %>
                        </td>
                        <td class="px-6 py-4 flex items-center space-x-4">
                            <a href="/admin/bulletins/<%= bulletin.id %>/edit" class="text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 font-bold text-xs uppercase tracking-widest">Edit</a>
                            <form action="/admin/bulletins/<%= bulletin.id %>/delete" method="POST" onsubmit="return confirm('Are you sure you want to delete this bulletin?')">
                                <button type="submit" class="text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300 font-bold text-xs uppercase tracking-widest">Delete</button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>
