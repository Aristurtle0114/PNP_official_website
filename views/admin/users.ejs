<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Add User Form -->
    <div class="lg:col-span-1">
        <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-gray-100 dark:border-slate-700 overflow-hidden">
            <div class="p-6 border-b border-gray-50 dark:border-slate-700">
                <h3 class="font-bold text-pnp-blue dark:text-pnp-gold uppercase tracking-widest text-xs">Create Admin Account</h3>
            </div>
            <form action="/admin/users/add" method="POST" class="p-6 space-y-6">
                <div class="space-y-2">
                    <label for="username" class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-widest font-bold">Username</label>
                    <input type="text" name="username" id="username" required placeholder="e.g., pnp_stacruz_admin" class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-lg focus:ring-2 focus:ring-pnp-blue outline-none text-sm font-bold text-gray-700 dark:text-gray-300">
                </div>
                <div class="space-y-2">
                    <label for="full_name" class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-widest font-bold">Full Name</label>
                    <input type="text" name="full_name" id="full_name" required placeholder="e.g., Juan Dela Cruz" class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-lg focus:ring-2 focus:ring-pnp-blue outline-none text-sm font-bold text-gray-700 dark:text-gray-300">
                </div>
                <div class="space-y-2">
                    <label for="password" class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-widest font-bold">Password</label>
                    <input type="password" name="password" id="password" required placeholder="••••••••" class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-lg focus:ring-2 focus:ring-pnp-blue outline-none text-sm font-bold text-gray-700 dark:text-gray-300">
                </div>
                <div class="space-y-2">
                    <label for="role" class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-widest font-bold">Role</label>
                    <select name="role" id="role" required class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-lg focus:ring-2 focus:ring-pnp-blue outline-none text-sm font-bold text-gray-700 dark:text-gray-300">
                        <option value="staff">Staff</option>
                        <option value="superadmin">Super Admin</option>
                    </select>
                </div>
                <button type="submit" class="w-full bg-pnp-blue text-white font-bold py-4 rounded-xl shadow-lg transition duration-300 hover:bg-blue-900 uppercase tracking-widest text-xs">
                    Create Account
                </button>
            </form>
        </div>
    </div>

    <!-- User List -->
    <div class="lg:col-span-2">
        <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-gray-100 dark:border-slate-700 overflow-hidden">
            <div class="p-6 border-b border-gray-50 dark:border-slate-700">
                <h3 class="font-bold text-pnp-blue dark:text-pnp-gold uppercase tracking-widest text-xs">Administrative Users</h3>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left text-sm">
                    <thead class="bg-gray-50 dark:bg-slate-900/50 text-gray-400 dark:text-gray-500 uppercase text-[10px] font-bold tracking-widest">
                        <tr>
                            <th class="px-6 py-4">Username</th>
                            <th class="px-6 py-4">Full Name</th>
                            <th class="px-6 py-4">Role</th>
                            <th class="px-6 py-4">Created At</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50 dark:divide-slate-700">
                        <% users.forEach(u => { %>
                            <tr class="hover:bg-gray-50 dark:hover:bg-slate-700/50 transition">
                                <td class="px-6 py-4 font-bold text-pnp-blue dark:text-pnp-gold"><%= u.username %></td>
                                <td class="px-6 py-4 text-gray-700 dark:text-gray-300"><%= u.full_name %></td>
                                <td class="px-6 py-4">
                                    <span class="px-2 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest <%= u.role === 'superadmin' ? 'bg-pnp-gold text-white' : 'bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400' %>">
                                        <%= u.role %>
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-gray-400 dark:text-gray-500 text-xs"><%= new Date(u.created_at).toLocaleDateString() %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
