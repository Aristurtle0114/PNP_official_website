<div class="max-w-4xl mx-auto">
    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-gray-100 dark:border-slate-700 overflow-hidden">
        <div class="p-8 border-b border-gray-50 dark:border-slate-700 flex justify-between items-center">
            <h3 class="font-bold text-pnp-blue dark:text-pnp-gold uppercase tracking-widest text-xs"><%= bulletin ? 'Edit Bulletin' : 'Create New Bulletin' %></h3>
            <a href="/admin/bulletins" class="text-[10px] font-bold text-gray-400 dark:text-gray-500 hover:text-pnp-blue dark:hover:text-pnp-gold uppercase tracking-widest">Cancel</a>
        </div>
        
        <form action="<%= bulletin ? '/admin/bulletins/' + bulletin.id + '/edit' : '/admin/bulletins/create' %>" method="POST" class="p-8 space-y-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Title -->
                <div class="md:col-span-2 space-y-2">
                    <label for="title" class="block text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest">Bulletin Title</label>
                    <input type="text" name="title" id="title" value="<%= bulletin ? bulletin.title : '' %>" required placeholder="Enter a clear, descriptive title" class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-lg focus:ring-2 focus:ring-pnp-blue outline-none text-sm font-bold dark:text-white">
                </div>
                
                <!-- Category -->
                <div class="space-y-2">
                    <label for="category" class="block text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest">Category</label>
                    <select name="category" id="category" required class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-lg focus:ring-2 focus:ring-pnp-blue outline-none text-sm font-bold dark:text-white">
                        <option value="" disabled <%= !bulletin ? 'selected' : '' %>>Select Category</option>
                        <option value="Wanted Person" <%= bulletin && bulletin.category === 'Wanted Person' ? 'selected' : '' %>>Wanted Person</option>
                        <option value="Missing Person" <%= bulletin && bulletin.category === 'Missing Person' ? 'selected' : '' %>>Missing Person</option>
                        <option value="Crime Advisory" <%= bulletin && bulletin.category === 'Crime Advisory' ? 'selected' : '' %>>Crime Advisory</option>
                        <option value="Recovered Property" <%= bulletin && bulletin.category === 'Recovered Property' ? 'selected' : '' %>>Recovered Property</option>
                        <option value="General Announcement" <%= bulletin && bulletin.category === 'General Announcement' ? 'selected' : '' %>>General Announcement</option>
                    </select>
                </div>

                <!-- Archive Status (Only on Edit) -->
                <% if (bulletin) { %>
                    <div class="space-y-2">
                        <label class="block text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest">Status</label>
                        <div class="flex items-center space-x-4 h-12">
                            <label class="flex items-center space-x-2 cursor-pointer">
                                <input type="checkbox" name="is_archived" value="1" <%= bulletin.is_archived ? 'checked' : '' %> class="w-5 h-5 rounded text-pnp-blue focus:ring-pnp-blue border-gray-300 dark:border-slate-600 dark:bg-slate-700">
                                <span class="text-sm font-bold text-gray-700 dark:text-gray-300">Archived</span>
                            </label>
                        </div>
                    </div>
                <% } %>
            </div>

            <!-- Body -->
            <div class="space-y-2">
                <label for="body" class="block text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest">Bulletin Body</label>
                <textarea name="body" id="body" rows="10" required placeholder="Enter the full content of the bulletin..." class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-lg focus:ring-2 focus:ring-pnp-blue outline-none text-sm leading-relaxed dark:text-white"><%= bulletin ? bulletin.body : '' %></textarea>
            </div>

            <!-- Photo URL (Simplified for now) -->
            <div class="space-y-2">
                <label for="photo_path" class="block text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest">Photo URL (Optional)</label>
                <input type="text" name="photo_path" id="photo_path" value="<%= bulletin ? bulletin.photo_path : '' %>" placeholder="https://example.com/photo.jpg" class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-lg focus:ring-2 focus:ring-pnp-blue outline-none text-sm dark:text-white">
            </div>

            <div class="pt-6 border-t border-gray-50 dark:border-slate-700">
                <button type="submit" class="w-full md:w-auto bg-pnp-blue text-white font-bold py-4 px-12 rounded-xl shadow-lg transition duration-300 hover:bg-blue-900 uppercase tracking-widest text-xs">
                    <%= bulletin ? 'Update Bulletin' : 'Post Bulletin' %>
                </button>
            </div>
        </form>
    </div>
</div>
