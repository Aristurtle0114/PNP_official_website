<!-- Top Row: Intelligence KPIs -->
<div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <a href="/admin/tips" class="bg-gradient-to-br from-purple-700 to-indigo-900 p-6 rounded-[2rem] shadow-2xl relative overflow-hidden group border border-white/10 transition-all hover:scale-[1.02]">
        <div class="absolute -right-4 -bottom-4 w-20 h-20 bg-white/10 rounded-full blur-2xl group-hover:bg-white/20 transition-all"></div>
        <div class="relative z-10">
            <div class="flex justify-between items-start mb-4">
                <span class="text-[10px] text-purple-200 font-black uppercase tracking-widest">Anonymous Tips</span>
                <div class="w-8 h-8 rounded-lg bg-white/20 flex items-center justify-center text-white">
                    <i class="fas fa-user-secret text-sm"></i>
                </div>
            </div>
            <div class="flex items-end space-x-3 mb-2">
                <h2 class="text-4xl font-black text-white leading-none"><%= todayStats.totalTips %></h2>
                <div class="flex items-center space-x-1 mb-1">
                    <span class="text-[10px] font-bold text-purple-300">Intel Received</span>
                </div>
            </div>
            <p class="text-[8px] text-purple-200/60 font-bold uppercase tracking-tighter">Strategic Intelligence Stream</p>
        </div>
    </a>

    <div class="bg-white dark:bg-slate-800 p-6 rounded-[2rem] shadow-sm border border-gray-100 dark:border-slate-700 flex flex-col justify-center items-center text-center group hover:shadow-xl transition-all duration-500 hover:-translate-y-1">
        <span class="text-[9px] text-gray-400 font-black uppercase tracking-widest mb-3">8-Focus Crimes</span>
        <div class="text-3xl font-black text-red-600 dark:text-red-500 mb-1"><%= todayStats.focus %></div>
        <div class="w-12 h-1 bg-red-100 dark:bg-red-900/30 rounded-full overflow-hidden">
            <div class="h-full bg-red-600 transition-all" style="width: <%= Math.min((todayStats.focus / (todayStats.total || 1)) * 100, 100) %>%"></div>
        </div>
    </div>

    <div class="bg-white dark:bg-slate-800 p-6 rounded-[2rem] shadow-sm border border-gray-100 dark:border-slate-700 flex flex-col justify-center items-center text-center group hover:shadow-xl transition-all duration-500 hover:-translate-y-1">
        <span class="text-[9px] text-gray-400 font-black uppercase tracking-widest mb-3">Non-Index Crimes</span>
        <div class="text-3xl font-black text-pnp-blue dark:text-pnp-gold mb-1"><%= todayStats.nonIndex %></div>
        <div class="w-12 h-1 bg-blue-100 dark:bg-blue-900/30 rounded-full overflow-hidden">
            <div class="h-full bg-pnp-blue transition-all" style="width: <%= Math.min((todayStats.nonIndex / (todayStats.total || 1)) * 100, 100) %>%"></div>
        </div>
    </div>

    <div class="bg-white dark:bg-slate-800 p-6 rounded-[2rem] shadow-sm border border-gray-100 dark:border-slate-700 flex flex-col justify-center items-center text-center group hover:shadow-xl transition-all duration-500 hover:-translate-y-1">
        <span class="text-[9px] text-gray-400 font-black uppercase tracking-widest mb-3">PSI Cases</span>
        <div class="text-3xl font-black text-purple-600 dark:text-purple-400 mb-1"><%= todayStats.psi %></div>
        <div class="w-12 h-1 bg-purple-100 dark:bg-purple-900/30 rounded-full overflow-hidden">
            <div class="h-full bg-purple-600 transition-all" style="width: <%= Math.min((todayStats.psi / (todayStats.total || 1)) * 100, 100) %>%"></div>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-8">
    <!-- Monthly Crime Trend Graph -->
    <div class="lg:col-span-2 bg-white dark:bg-slate-800 rounded-[2.5rem] shadow-sm border border-gray-100 dark:border-slate-700 p-8 flex flex-col h-[500px]">
        <div class="flex justify-between items-center mb-8">
            <div>
                <h3 class="font-black text-pnp-blue dark:text-white uppercase tracking-[0.2em] text-[11px]">Monthly Crime Trends</h3>
                <p class="text-[9px] text-gray-400 font-bold uppercase tracking-widest mt-1">Geospatial Intelligence Analysis (Last 6 Months)</p>
            </div>
            <div class="flex items-center space-x-6">
                <div class="flex items-center space-x-2">
                    <div class="w-2 h-2 rounded-full bg-[#ef4444]"></div>
                    <span class="text-[8px] font-black text-gray-400 uppercase">8-Focus</span>
                </div>
                <div class="flex items-center space-x-2">
                    <div class="w-2 h-2 rounded-full bg-[#001F3F]"></div>
                    <span class="text-[8px] font-black text-gray-400 uppercase">Non-Index</span>
                </div>
                <div class="flex items-center space-x-2">
                    <div class="w-2 h-2 rounded-full bg-[#D4AF37]"></div>
                    <span class="text-[8px] font-black text-gray-400 uppercase">PSI</span>
                </div>
            </div>
        </div>
        <div class="flex-1 relative">
            <canvas id="crimeTrendChart"></canvas>
        </div>
    </div>

    <!-- High-Risk Barangays -->
    <div class="bg-white dark:bg-slate-800 rounded-[2.5rem] shadow-sm border border-gray-100 dark:border-slate-700 p-8 flex flex-col h-[500px]">
        <div class="flex items-center justify-between mb-8 border-b border-gray-50 dark:border-slate-700 pb-4">
            <h3 class="font-black text-pnp-blue dark:text-white uppercase tracking-[0.2em] text-[11px]">High-Risk Barangays</h3>
            <i class="fas fa-biohazard text-red-500 text-sm animate-pulse"></i>
        </div>
        
        <div class="flex-1 overflow-y-auto space-y-4 pr-2 custom-scrollbar">
            <% highRiskBarangays.forEach(item => { %>
                <div class="p-5 bg-gray-50 dark:bg-slate-900 rounded-2xl border border-gray-100 dark:border-slate-700 group hover:shadow-lg transition-all duration-300">
                    <div class="flex justify-between items-center mb-3">
                        <div class="flex items-center space-x-3">
                            <div class="text-xs font-black text-pnp-blue dark:text-white uppercase">Brgy. <%= item.name %></div>
                        </div>
                        <span class="px-3 py-1 rounded-full text-[8px] font-black uppercase tracking-widest <%= item.risk === 'High' ? 'bg-red-500/10 text-red-500 border border-red-500/20' : (item.risk === 'Medium' ? 'bg-orange-500/10 text-orange-500 border border-orange-500/20' : 'bg-green-500/10 text-green-500 border border-green-500/20') %>">
                            <%= item.risk %> Risk
                        </span>
                    </div>
                    <div class="flex items-center space-x-4">
                        <div class="flex-1 h-1.5 bg-gray-200 dark:bg-slate-800 rounded-full overflow-hidden">
                            <div class="h-full <%= item.risk === 'High' ? 'bg-red-500' : (item.risk === 'Medium' ? 'bg-orange-500' : 'bg-green-500') %> transition-all duration-1000" style="width: <%= Math.min((item.count / 30) * 100, 100) %>%"></div>
                        </div>
                        <span class="text-[10px] font-black text-pnp-blue dark:text-pnp-gold"><%= item.count %></span>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</div>

<!-- Alerts Feed -->
<div class="bg-[#001F3F] p-8 rounded-[3rem] shadow-2xl border border-white/5 relative overflow-hidden">
    <div class="absolute -left-20 -bottom-20 w-60 h-60 bg-pnp-gold/5 rounded-full blur-3xl"></div>
    <div class="relative z-10">
        <div class="flex items-center justify-between mb-8">
            <div class="flex items-center space-x-4">
                <div class="w-10 h-10 bg-pnp-gold rounded-xl flex items-center justify-center text-pnp-blue shadow-lg shadow-pnp-gold/20">
                    <i class="fas fa-satellite text-sm"></i>
                </div>
                <div>
                    <h3 class="text-pnp-gold font-black uppercase tracking-[0.3em] text-[11px]">Tactical Command Stream</h3>
                    <div class="flex items-center space-x-2 mt-1">
                        <div class="w-1.5 h-1.5 bg-red-500 rounded-full animate-pulse"></div>
                        <span class="text-[8px] text-white/50 font-bold uppercase tracking-widest">Live Security Feed Active</span>
                    </div>
                </div>
            </div>
            <% if (notifications && notifications.length > 0) { %>
                <div class="flex items-center space-x-3 bg-red-500/20 px-4 py-2 rounded-xl border border-red-500/30 animate-pulse">
                    <i class="fas fa-bell text-red-500 text-[10px]"></i>
                    <span class="text-[9px] text-red-500 font-black uppercase tracking-widest"><%= notifications.length %> New Tips</span>
                </div>
            <% } %>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% alerts.forEach(alert => { %>
                <div class="p-6 bg-white/5 rounded-3xl border border-white/5 hover:bg-white/10 transition-all group flex flex-col h-full border-l-2 <%= alert.severity === 'Critical' ? 'border-l-red-500' : (alert.severity === 'Warning' ? 'border-l-pnp-gold' : 'border-l-blue-400') %>">
                    <div class="flex justify-between items-start mb-4">
                        <div class="flex items-center space-x-2">
                            <i class="fas <%= alert.severity === 'Critical' ? 'fa-exclamation-triangle text-red-500' : (alert.severity === 'Warning' ? 'fa-bolt text-pnp-gold' : 'fa-info-circle text-blue-400') %> text-[10px]"></i>
                            <span class="text-[8px] font-black uppercase tracking-widest <%= alert.severity === 'Critical' ? 'text-red-500' : (alert.severity === 'Warning' ? 'text-pnp-gold' : 'text-blue-400') %>"><%= alert.severity %> Alert</span>
                        </div>
                        <% 
                            let timeStr = 'N/A';
                            try {
                                if (alert.timestamp) {
                                    timeStr = new Date(alert.timestamp).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                                }
                            } catch (e) {
                                console.error('Date error:', e);
                            }
                        %>
                        <span class="text-[8px] text-white/30 font-bold uppercase"><%= timeStr %></span>
                    </div>
                    <div class="flex-1">
                        <p class="text-[10px] text-white font-black uppercase leading-tight mb-2 group-hover:text-pnp-gold transition-colors"><%= alert.message %></p>
                        <div class="flex items-center text-[8px] text-white/50 font-bold uppercase tracking-wide">
                            <i class="fas fa-map-marker-alt mr-2 text-pnp-gold"></i>
                            Brgy. <%= alert.location %>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const ctx = document.getElementById('crimeTrendChart').getContext('2d');
        const trendsData = JSON.parse('<%- monthlyTrends %>');
        
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: trendsData.map(d => d.month),
                datasets: [
                    {
                        label: '8-Focus Crimes',
                        data: trendsData.map(d => d.focus),
                        backgroundColor: '#ef4444',
                        borderRadius: 6,
                        barThickness: 12
                    },
                    {
                        label: 'Non-Index Crimes',
                        data: trendsData.map(d => d.nonIndex),
                        backgroundColor: '#001F3F',
                        borderRadius: 6,
                        barThickness: 12
                    },
                    {
                        label: 'PSI Cases',
                        data: trendsData.map(d => d.psi),
                        backgroundColor: '#D4AF37',
                        borderRadius: 6,
                        barThickness: 12
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    x: {
                        grid: { display: false },
                        ticks: { 
                            font: { size: 9, weight: 'bold' },
                            color: '#94a3b8'
                        }
                    },
                    y: {
                        beginAtZero: true,
                        grid: { 
                            color: 'rgba(0, 0, 0, 0.05)',
                            drawBorder: false
                        },
                        ticks: {
                            stepSize: 5,
                            font: { size: 9, weight: 'bold' },
                            color: '#94a3b8'
                        }
                    }
                }
            }
        });
    });
</script>

<style>
    .custom-scrollbar::-webkit-scrollbar {
        width: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(0, 31, 63, 0.1);
        border-radius: 10px;
    }
    .dark .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(212, 175, 55, 0.1);
    }
</style>
