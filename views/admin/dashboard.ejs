<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
    <!-- Stat Cards -->
    <div class="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-slate-700 flex flex-col items-center text-center group hover:shadow-md transition">
        <div class="w-12 h-12 bg-yellow-50 dark:bg-yellow-900/30 text-yellow-600 dark:text-yellow-400 rounded-full flex items-center justify-center mb-4 group-hover:bg-yellow-600 group-hover:text-white transition">
            <i class="fas fa-bullhorn text-xl"></i>
        </div>
        <p class="text-2xl font-bold text-gray-800 dark:text-white"><%= stats.activeBulletins %></p>
        <p class="text-[10px] text-gray-400 uppercase tracking-widest font-bold">Active Bulletins</p>
    </div>
    <div class="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-slate-700 flex flex-col items-center text-center group hover:shadow-md transition">
        <div class="w-12 h-12 bg-purple-50 dark:bg-purple-900/30 text-purple-600 dark:text-purple-400 rounded-full flex items-center justify-center mb-4 group-hover:bg-purple-600 group-hover:text-white transition">
            <i class="fas fa-user-secret text-xl"></i>
        </div>
        <p class="text-2xl font-bold text-gray-800 dark:text-white"><%= stats.tipsReceived %></p>
        <p class="text-[10px] text-gray-400 uppercase tracking-widest font-bold">Tips Received</p>
    </div>
    <div class="bg-white dark:bg-slate-800 p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-slate-700 flex flex-col items-center text-center group hover:shadow-md transition">
        <div class="w-12 h-12 bg-blue-50 dark:bg-blue-900/30 text-pnp-blue dark:text-blue-400 rounded-full flex items-center justify-center mb-4 group-hover:bg-pnp-blue group-hover:text-white transition">
            <i class="fas fa-users text-xl"></i>
        </div>
        <p class="text-2xl font-bold text-gray-800 dark:text-white"><%= stats.totalUsers %></p>
        <p class="text-[10px] text-gray-400 uppercase tracking-widest font-bold">System Users</p>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Recent Tips -->
    <div class="lg:col-span-2 bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-gray-100 dark:border-slate-700 overflow-hidden">
        <div class="p-6 border-b border-gray-50 dark:border-slate-700 flex justify-between items-center">
            <h3 class="font-bold text-pnp-blue dark:text-white uppercase tracking-widest text-xs">Recent Anonymous Tips</h3>
            <a href="/admin/tips" class="text-[10px] font-bold text-pnp-gold hover:underline uppercase tracking-widest">View All</a>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
                <thead class="bg-gray-50 dark:bg-slate-900/50 text-gray-400 uppercase text-[10px] font-bold tracking-widest">
                    <tr>
                        <th class="px-6 py-4">Tip ID</th>
                        <th class="px-6 py-4">Concern</th>
                        <th class="px-6 py-4">Location</th>
                        <th class="px-6 py-4">Date</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50 dark:divide-slate-700">
                    <% recentTips.forEach(tip => { %>
                        <tr class="hover:bg-gray-50 dark:hover:bg-slate-700/50 transition">
                            <td class="px-6 py-4 font-mono font-bold text-pnp-blue dark:text-pnp-gold"><%= tip.tip_id %></td>
                            <td class="px-6 py-4 font-medium text-gray-700 dark:text-gray-300"><%= tip.concern_type %></td>
                            <td class="px-6 py-4 text-gray-500 dark:text-gray-400"><%= tip.location_text %></td>
                            <td class="px-6 py-4 text-gray-400 text-xs"><%= new Date(tip.created_at).toLocaleDateString() %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Recent Activity Feed -->
    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-gray-100 dark:border-slate-700 overflow-hidden">
        <div class="p-6 border-b border-gray-50 dark:border-slate-700">
            <h3 class="font-bold text-pnp-blue dark:text-white uppercase tracking-widest text-xs">System Activity</h3>
        </div>
        <div class="p-6 space-y-6">
            <% recentLogs.forEach(log => { %>
                <div class="flex items-start space-x-4">
                    <div class="w-8 h-8 rounded-full bg-blue-50 dark:bg-blue-900/30 text-pnp-blue dark:text-blue-400 flex items-center justify-center flex-shrink-0">
                        <i class="fas fa-history text-xs"></i>
                    </div>
                    <div>
                        <p class="text-xs font-bold text-gray-800 dark:text-gray-200"><%= log.username %> <span class="text-gray-400 font-normal"><%= log.action %></span></p>
                        <p class="text-[10px] text-gray-500 dark:text-gray-400 mt-1 line-clamp-1"><%= log.details %></p>
                        <p class="text-[9px] text-gray-300 dark:text-gray-500 mt-1 uppercase font-bold"><%= new Date(log.timestamp).toLocaleTimeString() %></p>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mt-10">
    <!-- Recent Tips -->
    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-gray-100 dark:border-slate-700 overflow-hidden">
        <div class="p-6 border-b border-gray-50 dark:border-slate-700 flex justify-between items-center">
            <h3 class="font-bold text-pnp-blue dark:text-white uppercase tracking-widest text-xs">Recent Anonymous Tips</h3>
            <a href="/admin/tips" class="text-[10px] font-bold text-pnp-gold hover:underline uppercase tracking-widest">View All</a>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
                <thead class="bg-gray-50 dark:bg-slate-900/50 text-gray-400 uppercase text-[10px] font-bold tracking-widest">
                    <tr>
                        <th class="px-6 py-4">Tip ID</th>
                        <th class="px-6 py-4">Concern</th>
                        <th class="px-6 py-4">Location</th>
                        <th class="px-6 py-4">Flagged</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50 dark:divide-slate-700">
                    <% recentTips.forEach(tip => { %>
                        <tr class="hover:bg-gray-50 dark:hover:bg-slate-700/50 transition">
                            <td class="px-6 py-4 font-mono font-bold text-pnp-blue dark:text-pnp-gold"><%= tip.tip_id %></td>
                            <td class="px-6 py-4 font-medium text-gray-700 dark:text-gray-300"><%= tip.concern_type %></td>
                            <td class="px-6 py-4 text-gray-500 dark:text-gray-400"><%= tip.location_text %></td>
                            <td class="px-6 py-4">
                                <% if (tip.is_flagged) { %>
                                    <span class="text-red-500"><i class="fas fa-flag"></i></span>
                                <% } else { %>
                                    <span class="text-gray-200 dark:text-gray-700"><i class="fas fa-flag"></i></span>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    // Listen for dark mode changes
    const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
            if (mutation.attributeName === 'class') {
                // Handle any theme-specific updates if needed
            }
        });
    });
    observer.observe(document.documentElement, { attributes: true });
</script>
