<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Add Hotline Form -->
    <div class="lg:col-span-1">
        <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-gray-100 dark:border-slate-700 overflow-hidden">
            <div class="p-6 border-b border-gray-50 dark:border-slate-700">
                <h3 class="font-bold text-pnp-blue dark:text-pnp-gold uppercase tracking-widest text-xs">Add New Hotline</h3>
            </div>
            <form action="/admin/hotlines/add" method="POST" class="p-6 space-y-6">
                <div class="space-y-2">
                    <label for="agency_name" class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-widest font-bold">Agency Name</label>
                    <input type="text" name="agency_name" id="agency_name" required placeholder="e.g., PNP Sta. Cruz" class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-lg focus:ring-2 focus:ring-pnp-blue outline-none text-sm font-bold dark:text-white">
                </div>
                <div class="space-y-2">
                    <label for="contact_number" class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-widest font-bold">Contact Number</label>
                    <input type="text" name="contact_number" id="contact_number" required placeholder="e.g., 0912-345-6789" class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-lg focus:ring-2 focus:ring-pnp-blue outline-none text-sm font-bold dark:text-white">
                </div>
                <div class="space-y-2">
                    <label for="category" class="text-[10px] text-gray-400 dark:text-gray-500 uppercase tracking-widest font-bold">Category</label>
                    <select name="category" id="category" required class="w-full px-4 py-3 bg-gray-50 dark:bg-slate-900 border border-gray-200 dark:border-slate-700 rounded-lg focus:ring-2 focus:ring-pnp-blue outline-none text-sm font-bold dark:text-white">
                        <option value="Police">Police</option>
                        <option value="Fire">Fire</option>
                        <option value="Medical">Medical</option>
                        <option value="Disaster">Disaster</option>
                        <option value="Utility">Utility</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <button type="submit" class="w-full bg-pnp-blue text-white font-bold py-4 rounded-xl shadow-lg transition duration-300 hover:bg-blue-900 uppercase tracking-widest text-xs">
                    Save Hotline
                </button>
            </form>
        </div>
    </div>

    <!-- Hotline List -->
    <div class="lg:col-span-2">
        <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-gray-100 dark:border-slate-700 overflow-hidden">
            <div class="p-6 border-b border-gray-50 dark:border-slate-700">
                <h3 class="font-bold text-pnp-blue dark:text-pnp-gold uppercase tracking-widest text-xs">Emergency Directory</h3>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left text-sm">
                    <thead class="bg-gray-50 dark:bg-slate-900 text-gray-400 dark:text-gray-500 uppercase text-[10px] font-bold tracking-widest">
                        <tr>
                            <th class="px-6 py-4">Agency</th>
                            <th class="px-6 py-4">Number</th>
                            <th class="px-6 py-4">Category</th>
                            <th class="px-6 py-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50 dark:divide-slate-700">
                        <% hotlines.forEach(h => { %>
                            <tr class="hover:bg-gray-50 dark:hover:bg-slate-700 transition">
                                <td class="px-6 py-4 font-bold text-pnp-blue dark:text-pnp-gold"><%= h.agency_name %></td>
                                <td class="px-6 py-4 font-mono text-gray-700 dark:text-gray-300"><%= h.contact_number %></td>
                                <td class="px-6 py-4">
                                    <span class="px-2 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest bg-gray-100 dark:bg-slate-700 text-gray-600 dark:text-gray-400">
                                        <%= h.category %>
                                    </span>
                                </td>
                                <td class="px-6 py-4">
                                    <form action="/admin/hotlines/<%= h.id %>/delete" method="POST" onsubmit="return confirm('Delete this hotline?')">
                                        <button type="submit" class="text-red-600 hover:text-red-800 font-bold text-xs uppercase tracking-widest">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
