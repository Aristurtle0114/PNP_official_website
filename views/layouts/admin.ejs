<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - CPICRS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        pnp: {
                            blue: '#1A3A5C',
                            gold: '#C8A415',
                        }
                    }
                }
            }
        }
    </script>
    <script>
        // Check for dark mode preference
        if (localStorage.getItem('darkMode') === 'true' || (!('darkMode' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');
        body { font-family: 'Inter', sans-serif; }
        .bg-pnp-blue { background-color: #1A3A5C; }
        .text-pnp-blue { color: #1A3A5C; }
        .bg-pnp-gold { background-color: #C8A415; }
        .text-pnp-gold { color: #C8A415; }
        .border-pnp-gold { border-color: #C8A415; }

        /* Sidebar scrollbar hiding */
        .sidebar-scroll {
            scrollbar-width: none;
            -ms-overflow-style: none;
        }
        .sidebar-scroll::-webkit-scrollbar {
            display: none;
        }

        /* Sidebar toggle states */
        .sidebar-hidden {
            transform: translateX(-100%);
        }
        .main-content-expanded {
            margin-left: 0 !important;
            width: 100% !important;
        }

        @media (min-width: 1024px) {
            #sidebar:not(.sidebar-hidden) + #mainContent {
                margin-left: 18rem; /* w-72 matches aside width */
            }
        }
    </style>
</head>
<body class="bg-gray-50 dark:bg-slate-900 min-h-screen flex transition-colors duration-300 overflow-x-hidden">
    <!-- Sidebar -->
    <aside id="sidebar" class="w-72 bg-pnp-blue text-white flex flex-col fixed h-full z-50 shadow-2xl border-r-4 border-pnp-gold transition-transform duration-300 sidebar-scroll overflow-y-auto">
        <div class="p-8 border-b border-white/10 flex items-center justify-between">
            <div class="flex items-center space-x-4">
                <div class="w-10 h-10 bg-white rounded-xl flex items-center justify-center shadow-lg">
                    <i class="fas fa-shield-halved text-pnp-blue text-xl"></i>
                </div>
                <div>
                    <h1 class="text-lg font-black tracking-tighter leading-none">CPICRS</h1>
                    <p class="text-[9px] text-blue-200 uppercase tracking-widest font-bold mt-0.5">Admin</p>
                </div>
            </div>
            <button id="sidebarClose" class="lg:hidden text-white/50 hover:text-white transition">
                <i class="fas fa-times"></i>
            </button>
        </div>

        <nav class="flex-grow p-5 space-y-1">
            <p class="text-[9px] text-blue-400 uppercase tracking-widest font-black mb-3 px-4">Navigation</p>
            <a href="/admin/dashboard" class="flex items-center space-x-3 px-4 py-3 rounded-xl hover:bg-white/10 transition duration-300 group <%= title === 'Admin Command Center' ? 'bg-white/10 text-pnp-gold' : '' %>">
                <i class="fas fa-chart-pie text-[10px] group-hover:scale-110 transition"></i>
                <span class="text-[10px] font-bold uppercase tracking-widest">Dashboard</span>
            </a>
            <a href="/admin/bulletins" class="flex items-center space-x-3 px-4 py-3 rounded-xl hover:bg-white/10 transition duration-300 group <%= title === 'Bulletins' ? 'bg-white/10 text-pnp-gold' : '' %>">
                <i class="fas fa-bullhorn text-[10px] group-hover:scale-110 transition"></i>
                <span class="text-[10px] font-bold uppercase tracking-widest">Bulletins</span>
            </a>
            <a href="/admin/reports" class="flex items-center space-x-3 px-4 py-3 rounded-xl hover:bg-white/10 transition duration-300 group <%= title === 'Intelligence Reports' ? 'bg-white/10 text-pnp-gold' : '' %>">
                <i class="fas fa-file-invoice text-[10px] group-hover:scale-110 transition"></i>
                <span class="text-[10px] font-bold uppercase tracking-widest">Reports</span>
            </a>
            <a href="/admin/tips" class="flex items-center space-x-3 px-4 py-3 rounded-xl hover:bg-white/10 transition duration-300 group <%= title === 'Anonymous Tips' ? 'bg-white/10 text-pnp-gold' : '' %>">
                <i class="fas fa-user-secret text-[10px] group-hover:scale-110 transition"></i>
                <span class="text-[10px] font-bold uppercase tracking-widest">Tips</span>
            </a>
            <a href="/admin/map" class="flex items-center space-x-3 px-4 py-3 rounded-xl hover:bg-white/10 transition duration-300 group <%= title === 'Map Data' ? 'bg-white/10 text-pnp-gold' : '' %>">
                <i class="fas fa-map-marked-alt text-[10px] group-hover:scale-110 transition"></i>
                <span class="text-[10px] font-bold uppercase tracking-widest">Map</span>
            </a>
            <a href="/admin/hotlines" class="flex items-center space-x-3 px-4 py-3 rounded-xl hover:bg-white/10 transition duration-300 group <%= title === 'Hotlines' ? 'bg-white/10 text-pnp-gold' : '' %>">
                <i class="fas fa-phone-volume text-[10px] group-hover:scale-110 transition"></i>
                <span class="text-[10px] font-bold uppercase tracking-widest">Hotlines</span>
            </a>

            <% if (user && user.role === 'superadmin') { %>
                <p class="text-[9px] text-blue-400 uppercase tracking-widest font-black mt-8 mb-3 px-4">System</p>
                <a href="/admin/users" class="flex items-center space-x-3 px-4 py-3 rounded-xl hover:bg-white/10 transition duration-300 group <%= title === 'User Management' ? 'bg-white/10 text-pnp-gold' : '' %>">
                    <i class="fas fa-users-cog text-[10px] group-hover:scale-110 transition"></i>
                    <span class="text-[10px] font-bold uppercase tracking-widest">Users</span>
                </a>
                <a href="/admin/audit-log" class="flex items-center space-x-3 px-4 py-3 rounded-xl hover:bg-white/10 transition duration-300 group <%= title === 'Audit Log' ? 'bg-white/10 text-pnp-gold' : '' %>">
                    <i class="fas fa-history text-[10px] group-hover:scale-110 transition"></i>
                    <span class="text-[10px] font-bold uppercase tracking-widest">Audit</span>
                </a>
            <% } %>
        </nav>

        <div class="p-6 border-t border-white/10">
            <a href="/admin/logout" class="flex items-center space-x-3 px-4 py-3 rounded-xl bg-red-600/10 text-red-400 hover:bg-red-600 hover:text-white transition duration-300 group">
                <i class="fas fa-sign-out-alt text-[10px] group-hover:scale-110 transition"></i>
                <span class="text-[10px] font-bold uppercase tracking-widest">Logout</span>
            </a>
        </div>
    </aside>

    <!-- Main Content Area -->
    <div id="mainContent" class="flex-grow ml-72 flex flex-col min-h-screen transition-all duration-300">
        <!-- Top Header -->
        <header class="bg-white dark:bg-slate-800 h-20 border-b border-gray-100 dark:border-slate-700 flex items-center justify-between px-6 md:px-10 sticky top-0 z-40">
            <div class="flex items-center space-x-4">
                <button id="sidebarToggle" class="w-10 h-10 bg-gray-50 dark:bg-slate-700 hover:bg-gray-100 dark:hover:bg-slate-600 rounded-xl flex items-center justify-center text-pnp-blue dark:text-white transition border border-gray-100 dark:border-slate-600">
                    <i class="fas fa-bars"></i>
                </button>
                <div class="hidden sm:flex items-center space-x-4">
                    <h2 class="text-xl font-black text-pnp-blue dark:text-white tracking-tighter uppercase"><%= title %></h2>
                    <div class="w-1 h-1 bg-pnp-gold rounded-full"></div>
                    <p class="text-[9px] text-gray-400 font-bold uppercase tracking-widest">Intelligence Command</p>
                </div>
            </div>

            <div class="flex items-center space-x-8">
                <!-- Dark Mode Toggle -->
                <button id="darkModeToggle" class="w-10 h-10 bg-gray-50 dark:bg-slate-700 hover:bg-gray-100 dark:hover:bg-slate-600 rounded-xl flex items-center justify-center text-pnp-blue dark:text-white transition duration-300 border border-gray-100 dark:border-slate-600">
                    <i class="fas fa-moon dark:hidden"></i>
                    <i class="fas fa-sun hidden dark:block text-pnp-gold"></i>
                </button>

                <div class="text-right hidden sm:block">
                    <p class="text-xs font-black text-pnp-blue dark:text-white uppercase tracking-widest"><%= user ? user.full_name : 'Administrator' %></p>
                    <p class="text-[10px] text-pnp-gold font-bold uppercase tracking-widest"><%= user ? user.role : 'Staff' %></p>
                </div>
                <div class="w-12 h-12 bg-gray-50 rounded-2xl flex items-center justify-center border border-gray-100 shadow-sm">
                    <i class="fas fa-user-shield text-pnp-blue"></i>
                </div>
            </div>
        </header>

        <!-- Page Body -->
        <main class="p-10 flex-grow">
            <!-- Flash Messages -->
            <% if (typeof success_msg !== 'undefined' && success_msg) { %>
                <div class="bg-green-50 text-green-600 p-6 rounded-2xl text-xs font-bold uppercase tracking-widest mb-8 border border-green-100 flex items-center space-x-4 shadow-sm">
                    <i class="fas fa-check-circle text-lg"></i>
                    <span><%= success_msg %></span>
                </div>
            <% } %>
            <% if (typeof error_msg !== 'undefined' && error_msg) { %>
                <div class="bg-red-50 text-red-600 p-6 rounded-2xl text-xs font-bold uppercase tracking-widest mb-8 border border-red-100 flex items-center space-x-4 shadow-sm">
                    <i class="fas fa-exclamation-circle text-lg"></i>
                    <span><%= error_msg %></span>
                </div>
            <% } %>

            <%- body %>
        </main>

        <!-- Footer -->
        <footer class="bg-white dark:bg-slate-800 py-6 px-10 border-t border-gray-100 dark:border-slate-700 flex justify-between items-center">
            <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">
                &copy; 2026 PNP Sta. Cruz Municipal Police Station - CPICRS Admin
            </p>
            <div class="flex items-center space-x-2 text-[10px] text-gray-400 font-bold uppercase tracking-widest">
                <span class="w-2 h-2 rounded-full bg-green-500"></span>
                <span>System Online</span>
            </div>
        </footer>
    </div>
    <script>
        const darkModeToggle = document.getElementById('darkModeToggle');
        darkModeToggle.addEventListener('click', () => {
            document.documentElement.classList.toggle('dark');
            localStorage.setItem('darkMode', document.documentElement.classList.contains('dark'));
        });

        // Sidebar Toggle Logic
        const sidebarToggle = document.getElementById('sidebarToggle');
        const sidebarClose = document.getElementById('sidebarClose');
        const sidebar = document.getElementById('sidebar');
        const mainContent = document.getElementById('mainContent');

        const toggleSidebar = () => {
            sidebar.classList.toggle('sidebar-hidden');
            mainContent.classList.toggle('main-content-expanded');
            localStorage.setItem('sidebarHidden', sidebar.classList.contains('sidebar-hidden'));
        };

        sidebarToggle.addEventListener('click', toggleSidebar);
        sidebarClose.addEventListener('click', toggleSidebar);

        // Responsive Sidebar Initial State
        if (window.innerWidth < 1024) {
            sidebar.classList.add('sidebar-hidden');
            mainContent.classList.add('main-content-expanded');
        } else if (localStorage.getItem('sidebarHidden') === 'true') {
            sidebar.classList.add('sidebar-hidden');
            mainContent.classList.add('main-content-expanded');
        }
    </script>
</body>
</html>
