<!-- Hero Section -->
<section class="bg-pnp-blue text-white py-20 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-cover bg-center" style="background-image: url('https://picsum.photos/seed/pnp-patrol/1920/1080');"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
        <h1 class="text-4xl md:text-6xl font-extrabold text-pnp-gold mb-4 tracking-tight">STA. CRUZ CRIME MAPPING SYSTEM</h1>
        <p class="text-xl md:text-2xl font-light max-w-3xl mx-auto">Interactive incident visualization and community-based reporting for a safer Sta. Cruz, Laguna.</p>
    </div>
</section>

<!-- Key Personnel / Leadership -->
<section class="py-20 bg-white dark:bg-slate-800 transition-colors duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
            <h2 class="text-xs font-black text-pnp-gold uppercase tracking-[0.3em] mb-3">Leadership & Command</h2>
            <h3 class="text-4xl font-black text-pnp-blue dark:text-white tracking-tighter">KEY PERSONNEL</h3>
            <div class="w-20 h-1.5 bg-pnp-gold mx-auto mt-6 rounded-full"></div>
        </div>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">
            <!-- Chief of Police -->
            <div class="group">
                <div class="relative mb-6">
                    <div class="aspect-[3/4] rounded-[2.5rem] overflow-hidden shadow-2xl border-4 border-white dark:border-slate-700 relative z-10 group-hover:-translate-y-2 transition duration-500">
                        <img src="https://picsum.photos/seed/pnp-chief/600/800" alt="Chief of Police" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition duration-500" referrerPolicy="no-referrer">
                    </div>
                    <div class="absolute -bottom-4 -right-4 w-24 h-24 bg-pnp-gold rounded-[2rem] -z-0 opacity-20 group-hover:scale-110 transition duration-500"></div>
                </div>
                <div class="text-center">
                    <h4 class="text-xl font-black text-pnp-blue dark:text-pnp-gold tracking-tight">PLTCOL. JUAN DELA CRUZ</h4>
                    <p class="text-[10px] font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest mt-1">Chief of Police</p>
                </div>
            </div>

            <!-- Deputy Chief -->
            <div class="group">
                <div class="relative mb-6">
                    <div class="aspect-[3/4] rounded-[2.5rem] overflow-hidden shadow-2xl border-4 border-white dark:border-slate-700 relative z-10 group-hover:-translate-y-2 transition duration-500">
                        <img src="https://picsum.photos/seed/pnp-deputy/600/800" alt="Deputy Chief" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition duration-500" referrerPolicy="no-referrer">
                    </div>
                    <div class="absolute -bottom-4 -right-4 w-24 h-24 bg-pnp-blue rounded-[2rem] -z-0 opacity-20 group-hover:scale-110 transition duration-500"></div>
                </div>
                <div class="text-center">
                    <h4 class="text-xl font-black text-pnp-blue dark:text-pnp-gold tracking-tight">PMAJ. RICARDO DALISAY</h4>
                    <p class="text-[10px] font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest mt-1">Deputy Chief of Police</p>
                </div>
            </div>

            <!-- Operations Section -->
            <div class="group">
                <div class="relative mb-6">
                    <div class="aspect-[3/4] rounded-[2.5rem] overflow-hidden shadow-2xl border-4 border-white dark:border-slate-700 relative z-10 group-hover:-translate-y-2 transition duration-500">
                        <img src="https://picsum.photos/seed/pnp-officer-1/600/800" alt="Operations Chief" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition duration-500" referrerPolicy="no-referrer">
                    </div>
                    <div class="absolute -bottom-4 -right-4 w-24 h-24 bg-pnp-gold rounded-[2rem] -z-0 opacity-20 group-hover:scale-110 transition duration-500"></div>
                </div>
                <div class="text-center">
                    <h4 class="text-xl font-black text-pnp-blue dark:text-pnp-gold tracking-tight">PCAPT. MARIA CLARA</h4>
                    <p class="text-[10px] font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest mt-1">Chief, Operations Section</p>
                </div>
            </div>

            <!-- Investigation Section -->
            <div class="group">
                <div class="relative mb-6">
                    <div class="aspect-[3/4] rounded-[2.5rem] overflow-hidden shadow-2xl border-4 border-white dark:border-slate-700 relative z-10 group-hover:-translate-y-2 transition duration-500">
                        <img src="https://picsum.photos/seed/pnp-officer-2/600/800" alt="Investigation Chief" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition duration-500" referrerPolicy="no-referrer">
                    </div>
                    <div class="absolute -bottom-4 -right-4 w-24 h-24 bg-pnp-blue rounded-[2rem] -z-0 opacity-20 group-hover:scale-110 transition duration-500"></div>
                </div>
                <div class="text-center">
                    <h4 class="text-xl font-black text-pnp-blue dark:text-pnp-gold tracking-tight">PLT. JOSE RIZAL</h4>
                    <p class="text-[10px] font-black text-gray-400 dark:text-gray-500 uppercase tracking-widest mt-1">Chief, Investigation Section</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Stats Bar -->
<section class="bg-gray-100 dark:bg-slate-900 py-8 border-y border-gray-200 dark:border-slate-800 transition-colors duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-center">
            <div>
                <p class="text-3xl font-bold text-pnp-blue dark:text-pnp-gold"><%= stats.activeBulletins %></p>
                <p class="text-sm text-gray-600 dark:text-gray-400 uppercase tracking-wider font-semibold">Active Bulletins</p>
            </div>
            <div>
                <p class="text-3xl font-bold text-pnp-blue dark:text-pnp-gold"><%= stats.tipsReceived %></p>
                <p class="text-sm text-gray-600 dark:text-gray-400 uppercase tracking-wider font-semibold">Tips Received</p>
            </div>
        </div>
    </div>
</section>

<!-- Mission & Vision -->
<section class="py-16 bg-white dark:bg-slate-800 transition-colors duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
            <div>
                <img src="https://picsum.photos/seed/pnp-station-exterior/600/400" alt="Sta. Cruz" class="rounded-2xl shadow-2xl dark:opacity-80">
            </div>
            <div class="space-y-8">
                <div>
                    <h2 class="text-2xl font-bold text-pnp-blue dark:text-white border-l-4 border-pnp-gold pl-4 mb-4 uppercase tracking-wider">Our Mission</h2>
                    <p class="text-gray-700 dark:text-gray-300 leading-relaxed">To enforce the law, to prevent and control crimes, to maintain peace and order, and to ensure public safety and internal security with the active support of the community.</p>
                </div>
                <div>
                    <h2 class="text-2xl font-bold text-pnp-blue dark:text-white border-l-4 border-pnp-gold pl-4 mb-4 uppercase tracking-wider">Our Vision</h2>
                    <p class="text-gray-700 dark:text-gray-300 leading-relaxed">Imploring the aid of the Almighty, by 2030, PNP Sta. Cruz shall be a highly capable, effective and credible police service working in partnership with a responsive community towards the attainment of a safer place to live, work and do business.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Emergency Hotlines -->
<section class="py-16 bg-gray-50 dark:bg-slate-900 transition-colors duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
            <h2 class="text-3xl font-bold text-pnp-blue dark:text-white mb-4">Emergency Hotlines</h2>
            <p class="text-gray-600 dark:text-gray-400">Quick access to essential services in Sta. Cruz, Laguna.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% hotlines.forEach(hotline => { %>
                <div class="bg-white dark:bg-slate-800 p-6 rounded-xl shadow-sm border border-gray-100 dark:border-slate-700 flex items-center space-x-4">
                    <div class="w-12 h-12 bg-red-50 dark:bg-red-900/30 text-red-600 dark:text-red-400 rounded-full flex items-center justify-center flex-shrink-0">
                        <i class="fas fa-phone-volume"></i>
                    </div>
                    <div>
                        <h3 class="font-bold text-gray-800 dark:text-gray-200"><%= hotline.name %></h3>
                        <p class="text-red-600 dark:text-red-400 font-mono text-lg font-bold"><%= hotline.number %></p>
                        <span class="text-xs text-gray-400 dark:text-gray-500 uppercase tracking-widest"><%= hotline.category %></span>
                    </div>
                </div>
            <% }) %>
        </div>
        <div class="text-center mt-10">
            <a href="/hotlines" class="text-pnp-blue dark:text-pnp-gold font-bold hover:text-pnp-gold underline">View All Hotlines</a>
        </div>
    </div>
</section>
