    let boundaryLayer;
    let glowLayer;

    async function loadMunicipalBoundary() {
        try {
            console.log("Fetching municipal boundary for Sta. Cruz, Laguna...");
            // Use a more specific query including Philippines to avoid ambiguity
            const response = await fetch('https://nominatim.openstreetmap.org/search?format=json&q=Santa+Cruz,+Laguna,+Philippines&polygon_geojson=1&limit=5');
            const data = await response.json();
            
            // Find the administrative boundary relation (usually the most accurate for municipalities)
            const boundary = data.find(item => 
                item.osm_type === 'relation' && 
                item.geojson && 
                (item.addresstype === 'municipality' || item.type === 'administrative')
            ) || (data[0] && data[0].geojson ? data[0] : null);

            if (boundary && boundary.geojson) {
                const updateStyles = () => {
                    const zoom = map.getZoom();
                    // Dynamic weight based on zoom level: make it much thicker as we zoom in
                    const baseWeight = zoom < 14 ? 10 : (zoom < 16 ? 18 : 30);
                    const glowWeight = baseWeight * 1.8;

                    if (glowLayer) glowLayer.setStyle({ weight: glowWeight });
                    if (boundaryLayer) boundaryLayer.setStyle({ weight: baseWeight });
                };

                // 1. Add an outer glow/shadow for contrast
                glowLayer = L.geoJSON(boundary.geojson, {
                    style: {
                        color: "#000000",
                        weight: 25,
                        opacity: 0.25,
                        fillColor: "transparent",
                        interactive: false
                    }
                }).addTo(map);

                // 2. The main prominent "Pitch Black" border
                boundaryLayer = L.geoJSON(boundary.geojson, {
                    style: {
                        color: "#000000",
                        weight: 12,
                        opacity: 1,
                        fillColor: "rgba(0, 0, 0, 0.05)",
                        fillOpacity: 0.1,
                        lineCap: 'round',
                        lineJoin: 'round',
                        interactive: false
                    }
                }).addTo(map);

                // Update on zoom
                map.on('zoomend', updateStyles);
                updateStyles();

                console.log("Municipal boundary successfully rendered (Responsive):", boundary.display_name);
            } else {
                console.warn("Could not find a valid boundary polygon for Santa Cruz, Laguna.");
            }
        } catch (err) {
            console.error("Error loading municipal boundary:", err);
        }
    }

    function locateBarangay(shouldMinimize = true) {
        const selectedName = document.getElementById('filterBarangay').value;
        if (!selectedName) {
            // Reset to default view if "All Barangays" is selected
            const bounds = [[14.2100, 121.3400], [14.3100, 121.4850]];
            const isMobile = window.innerWidth < 768;
            map.flyToBounds(bounds, {
                padding: isMobile ? [20, 20] : [50, 50],
                duration: 1.5
            });
            // Disable interaction when in summary view
            map.dragging.disable();
            map.touchZoom.disable();
            map.doubleClickZoom.disable();
            map.scrollWheelZoom.disable();
            map.boxZoom.disable();
            map.keyboard.disable();
            return;
        }

        const pin = manualPins.find(p => p.name.toLowerCase() === selectedName.toLowerCase());
        if (pin && map) {
            // Enable interaction when a barangay is selected
            map.dragging.enable();
            map.touchZoom.enable();
            map.doubleClickZoom.enable();
            map.scrollWheelZoom.enable();
            map.boxZoom.enable();
            map.keyboard.enable();
            // Minimize sidebar to view the whole map if requested
            const sidebar = document.getElementById('filterSidebar');
            if (shouldMinimize && sidebar && sidebar.classList.contains('sidebar-visible')) {
                toggleSidebar();
            }

            const isMobile = window.innerWidth < 768;
            map.flyTo([pin.lat, pin.lng], isMobile ? 15 : 16, {
                animate: true,
                duration: 1.5
            });
            
            // Open popup after a short delay to allow flyTo to finish
            setTimeout(() => {
                map.eachLayer((layer) => {
                    if (layer instanceof L.Marker) {
                        const latlng = layer.getLatLng();
                        if (latlng.lat === pin.lat && latlng.lng === pin.lng) {
                            layer.openPopup();
                        }
                    }
                });
                
                // Re-open sidebar to show stats after zoom is complete if it was minimized
                if (shouldMinimize && sidebar && sidebar.classList.contains('sidebar-hidden')) {
                    toggleSidebar();
                }
            }, 1600);
        }
    }

