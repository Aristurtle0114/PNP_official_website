<script>
    let map;
    let searchMarker;
    let santaCruzGeoJSON;
    let incidentMarkers = L.layerGroup();
    const barangayGeoJsonUrl = 'https://raw.githubusercontent.com/faeldon/philippines-json-maps/master/2019/geojson/barangay/philippines-barangay-043424000.json';

    const colors = {
        'Theft': '#dc2626',
        'Vandalism': '#f97316',
        'Assault': '#7f1d1d',
        'Suspicious Activity': '#eab308',
        'Robbery': '#9333ea',
        'Other': '#6b7280'
    };

    function hideLoading() {
        const loading = document.getElementById('mapLoading');
        if (loading) {
            loading.classList.add('opacity-0');
            setTimeout(() => {
                loading.classList.add('hidden');
            }, 500);
        }
    }

    function locateBarangay(shouldMinimize = true) {
        const selectedName = document.getElementById('filterBarangay').value;
        if (!selectedName) {
            // Reset to default view if "All Barangays" is selected
            const bounds = [[14.2100, 121.3400], [14.3100, 121.4850]];
            map.flyToBounds(bounds, {
                padding: [50, 50],
                duration: 1.5
            });
            return;
        }

        const pin = manualPins.find(p => p.name.toLowerCase() === selectedName.toLowerCase());
        if (pin && map) {
            // Minimize sidebar to view the whole map if requested
            const sidebar = document.getElementById('filterSidebar');
            if (shouldMinimize && sidebar && sidebar.classList.contains('sidebar-visible')) {
                toggleSidebar();
            }

            map.flyTo([pin.lat, pin.lng], 16, {
                animate: true,
                duration: 1.5
            });
            
            // Open popup after a short delay to allow flyTo to finish
            setTimeout(() => {
                map.eachLayer((layer) => {
                    if (layer instanceof L.Marker) {
                        const latlng = layer.getLatLng();
                        if (latlng.lat === pin.lat && latlng.lng === pin.lng) {
                            layer.openPopup();
                        }
                    }
                });
                
                // Re-open sidebar to show stats after zoom is complete if it was minimized
                if (shouldMinimize && sidebar && sidebar.classList.contains('sidebar-hidden')) {
                    toggleSidebar();
                }
            }, 1600);
        }
    }

    async function loadMapPoints(shouldLocate = true) {
        const range = document.getElementById('filterRange').value;
        const barangay = document.getElementById('filterBarangay').value;
        
        // Automatically locate when barangay is selected
        if (barangay && shouldLocate) {
            locateBarangay();
        } else if (!barangay && shouldLocate) {
            // Optional: reset view when "All Barangays" is selected
            const bounds = [[14.2100, 121.3400], [14.3100, 121.4850]];
            map.flyToBounds(bounds, { padding: [50, 50], duration: 1.5 });
        }
        
        const mapInfoSection = document.getElementById('mapInfoSection');
        const topIncidentsSection = document.getElementById('topIncidentsSection');
        const topIncidentsList = document.getElementById('topIncidentsList');

        if (barangay) {
            mapInfoSection.classList.add('hidden');
            topIncidentsSection.classList.remove('hidden');
            
            const rangeText = {
                '': 'All Time',
                '7days': 'Last 7 Days',
                '30days': 'Last 30 Days',
                '6months': 'Last 6 Months'
            };
            document.getElementById('topIncidentsRange').textContent = rangeText[range] || 'All Time';
        } else {
            mapInfoSection.classList.remove('hidden');
            topIncidentsSection.classList.add('hidden');
        }

        try {
            const url = `/api/map-points?range=${range}&barangay=${barangay}`;
            const response = await fetch(url);
            const points = await response.json();

            incidentMarkers.clearLayers();

            // Calculate Top 3 Incidents
            const incidentCounts = {};
            points.forEach(point => {
                incidentCounts[point.incident_type] = (incidentCounts[point.incident_type] || 0) + 1;
            });

            const sortedIncidents = Object.entries(incidentCounts)
                .sort((a, b) => b[1] - a[1])
                .slice(0, 3);

            if (barangay) {
                topIncidentsList.innerHTML = sortedIncidents.length > 0 
                    ? sortedIncidents.map(([type, count]) => `
                        <div class="flex items-center justify-between p-4 bg-gray-50 dark:bg-slate-900 rounded-2xl border border-gray-100 dark:border-slate-700">
                            <div class="flex items-center space-x-3">
                                <span class="w-2 h-2 rounded-full" style="background-color: ${colors[type] || '#6b7280'}"></span>
                                <span class="text-[10px] font-black text-gray-700 dark:text-gray-300 uppercase tracking-widest">${type}</span>
                            </div>
                            <span class="text-xs font-black text-pnp-blue dark:text-pnp-gold">${count}</span>
                        </div>
                    `).join('')
                    : `<p class="text-[10px] text-gray-400 font-bold uppercase text-center py-4">No incidents recorded</p>`;
            }

            // Crime dots are no longer added to the map per user request.
            // All crimes are visible through the sidebar summary.
            /*
            points.forEach(point => {
                const marker = L.circleMarker([point.lat, point.lng], {
                    radius: 8,
                    fillColor: colors[point.incident_type] || '#6b7280',
                    color: '#FFFFFF',
                    weight: 2,
                    opacity: 1,
                    fillOpacity: 0.8
                });

                marker.bindPopup(`
                    <div class="p-2 min-w-[150px]">
                        <h3 class="text-pnp-blue font-black uppercase tracking-widest text-xs mb-1">${point.incident_type}</h3>
                        <p class="text-[9px] text-gray-500 font-bold uppercase mb-2">${new Date(point.incident_date).toLocaleDateString()}</p>
                        <p class="text-[10px] text-gray-700 dark:text-gray-300 font-medium leading-relaxed">
                            ${point.description || 'No additional details provided.'}
                        </p>
                    </div>
                `);

                incidentMarkers.addLayer(marker);
            });

            incidentMarkers.addTo(map);
            */
        } catch (err) {
            console.error('Error loading map points:', err);
        }
    }

    // Simple Point in Polygon function
    function isPointInPolygon(point, vs) {
        const x = point[0], y = point[1];
        let inside = false;
        
        if (Array.isArray(vs[0][0][0])) {
            for (let i = 0; i < vs.length; i++) {
                if (isPointInPolygon(point, vs[i])) return true;
            }
            return false;
        }

        const polygon = Array.isArray(vs[0][0]) ? vs[0] : vs;

        for (let i = 0, j = polygon.length - 1; i < polygon.length; j = i++) {
            const xi = polygon[i][0], yi = polygon[i][1];
            const xj = polygon[j][0], yj = polygon[j][1];
            const intersect = ((yi > y) !== (yj > y)) && (x < (xj - xi) * (y - yi) / (yj - yi) + xi);
            if (intersect) inside = !inside;
        }
        return inside;
    }

    function checkGeofence(latlng) {
        let isInside = false;
        if (santaCruzGeoJSON) {
            const point = [latlng.lng, latlng.lat];
            for (const feature of santaCruzGeoJSON.features) {
                if (isPointInPolygon(point, feature.geometry.coordinates)) {
                    isInside = true;
                    break;
                }
            }
        }
        return isInside;
    }

    const manualPins = [
        { name: 'Alipit', lat: 14.223931, lng: 121.405213 },
        { name: 'Bagumbayan', lat: 14.268334, lng: 121.398454 },
        { name: 'Duhat', lat: 14.2525, lng: 121.3825 },
        { name: 'Bubukal', lat: 14.256460, lng: 121.399183 },
        { name: 'Calios', lat: 14.2750, lng: 121.4050 },
        { name: 'Gatid', lat: 14.2600, lng: 121.3830 },
        { name: 'Jasaan', lat: 14.223577, lng: 121.394827 },
        { name: 'Labuin', lat: 14.250158, lng: 121.400664 },
        { name: 'Malinao', lat: 14.232833, lng: 121.396823 },
        { name: 'Oogong', lat: 14.226323, lng: 121.400621 },
        { name: 'Pagsawitan', lat: 14.265754, lng: 121.426545 },
        { name: 'Palasan', lat: 14.257498, lng: 121.418992 },
        { name: 'Patimbao', lat: 14.270081, lng: 121.418366 },
        { name: 'Poblacion I (Barangay I)', lat: 14.277068, lng: 121.418881 },
        { name: 'Poblacion II (Barangay II)', lat: 14.279647, lng: 121.416006 },
        { name: 'Poblacion III (Barangay III)', lat: 14.282028, lng: 121.415159 },
        { name: 'Poblacion IV (Barangay IV)', lat: 14.283790, lng: 121.414016 },
        { name: 'Poblacion V (Barangay V)', lat: 14.285282, lng: 121.412476 },
        { name: 'San Jose', lat: 14.237118, lng: 121.403754 },
        { name: 'San Juan', lat: 14.243815, lng: 121.406972 },
        { name: 'San Pablo Norte', lat: 14.290210, lng: 121.413023 },
        { name: 'San Pablo Sur', lat: 14.282211, lng: 121.422261 },
        { name: 'Santisima Cruz', lat: 14.290647, lng: 121.409140 },
        { name: 'Santo Angel Central', lat: 14.285137, lng: 121.408947 },
        { name: 'Santo Angel Norte', lat: 14.288547, lng: 121.406307 },
        { name: 'Santo Angel Sur', lat: 14.282329, lng: 121.410985 }
    ];

    function addManualPins() {
        manualPins.forEach(pin => {
            const marker = L.marker([pin.lat, pin.lng], {
                icon: L.divIcon({
                    className: 'manual-pin-container',
                    html: `
                        <div class="relative group flex flex-col items-center">
                            <!-- Pulse Effect -->
                            <div class="absolute w-8 h-8 bg-pnp-gold/30 rounded-full animate-ping"></div>
                            <!-- Main Pin -->
                            <div class="relative w-10 h-10 bg-pnp-blue dark:bg-pnp-gold rounded-full flex items-center justify-center shadow-2xl border-2 border-white dark:border-slate-900 transform group-hover:scale-110 transition-all duration-300">
                                <i class="fas fa-location-dot text-white dark:text-pnp-blue text-lg"></i>
                            </div>
                            <!-- Pointer -->
                            <div class="w-0 h-0 border-l-[6px] border-l-transparent border-r-[6px] border-r-transparent border-t-[8px] border-t-pnp-blue dark:border-t-pnp-gold -mt-1"></div>
                        </div>
                    `,
                    iconSize: [40, 48],
                    iconAnchor: [20, 48]
                })
            }).addTo(map);

            marker.on('click', () => {
                const barangaySelect = document.getElementById('filterBarangay');
                if (barangaySelect) {
                    barangaySelect.value = pin.name;
                    // Trigger loadMapPoints to update sidebar stats, but don't re-locate
                    loadMapPoints(false);
                    
                    // Ensure sidebar is visible to show the stats
                    const sidebar = document.getElementById('filterSidebar');
                    if (sidebar && sidebar.classList.contains('sidebar-hidden')) {
                        toggleSidebar();
                    }
                }
            });

            marker.bindPopup(`
                <div class="p-4 min-w-[200px] bg-white dark:bg-slate-800 rounded-xl">
                    <div class="flex items-center space-x-3 mb-3 pb-3 border-b border-gray-100 dark:border-slate-700">
                        <div class="w-8 h-8 bg-pnp-blue dark:bg-pnp-gold rounded-lg flex items-center justify-center">
                            <i class="fas fa-shield-halved text-white dark:text-pnp-blue text-xs"></i>
                        </div>
                        <div>
                            <h3 class="text-pnp-blue dark:text-pnp-gold font-black uppercase tracking-widest text-xs leading-none">${pin.name}</h3>
                            <p class="text-[8px] text-gray-400 font-bold uppercase mt-1">Sta. Cruz, Laguna</p>
                        </div>
                    </div>
                    <div class="space-y-2">
                        <div class="flex justify-between items-center">
                            <span class="text-[9px] text-gray-500 font-bold uppercase">Classification</span>
                            <span class="px-2 py-0.5 bg-blue-50 dark:bg-blue-900/30 text-pnp-blue dark:text-blue-400 rounded-full text-[8px] font-black uppercase">Reference Point</span>
                        </div>
                        <div class="p-3 bg-gray-50 dark:bg-slate-900 rounded-xl border border-gray-100 dark:border-slate-700">
                            <div class="flex justify-between items-center mb-1">
                                <span class="text-[8px] font-black text-gray-400 uppercase">Latitude</span>
                                <span class="text-[9px] font-mono font-bold text-gray-700 dark:text-gray-300">${pin.lat.toFixed(6)}</span>
                            </div>
                            <div class="flex justify-between items-center">
                                <span class="text-[8px] font-black text-gray-400 uppercase">Longitude</span>
                                <span class="text-[9px] font-mono font-bold text-gray-700 dark:text-gray-300">${pin.lng.toFixed(6)}</span>
                            </div>
                        </div>
                    </div>
                </div>
            `, {
                className: 'custom-pnp-popup',
                maxWidth: 300
            });
        });
    }

    function initMap() {
        try {
            // Shifted bounds slightly north and west to center Sta. Cruz
            const bounds = [[14.2100, 121.3400], [14.3100, 121.4850]];
            
            map = L.map('leafletMap', {
                zoomControl: true,
                dragging: true,
                touchZoom: true,
                doubleClickZoom: true,
                scrollWheelZoom: true,
                boxZoom: true,
                keyboard: true,
                attributionControl: true
            }).fitBounds(bounds);
            
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
            }).addTo(map);

            // Initialize incident markers layer
            incidentMarkers.addTo(map);
            loadMapPoints();

            addManualPins();

            // Track mouse movement for live coordinates
            map.on('mousemove', (e) => {
                document.getElementById('liveLat').textContent = e.latlng.lat.toFixed(6);
                document.getElementById('liveLng').textContent = e.latlng.lng.toFixed(6);
            });

            // Hide loading as soon as map is initialized
            hideLoading();

            // Load Barangay GeoJSON
            fetch(barangayGeoJsonUrl)
                .then(res => {
                    if (!res.ok) throw new Error('Network response was not ok');
                    return res.json();
                })
                .then(data => {
                    santaCruzGeoJSON = data;
                    L.geoJSON(data, {
                        style: function(feature) {
                            return {
                                fillColor: '#1A3A5C',
                                fillOpacity: 0.1,
                                weight: 2,
                                color: '#C8A415'
                            };
                        },
                        onEachFeature: function(feature, layer) {
                            const name = feature.properties.NAME_3;
                            
                            layer.on({
                                mouseover: function(e) {
                                    const layer = e.target;
                                    layer.setStyle({
                                        fillOpacity: 0.3,
                                        weight: 3
                                    });
                                },
                                mouseout: function(e) {
                                    const layer = e.target;
                                    layer.setStyle({
                                        fillOpacity: 0.1,
                                        weight: 2
                                    });
                                }
                            });

                            // Add marker for each barangay
                            try {
                                const centroid = layer.getBounds().getCenter();
                                const marker = L.circleMarker(centroid, {
                                    radius: 6,
                                    fillColor: '#C8A415',
                                    color: '#1A3A5C',
                                    weight: 2,
                                    opacity: 1,
                                    fillOpacity: 1
                                }).addTo(map);

                                marker.bindPopup(`
                                    <div class="p-2 min-w-[150px]">
                                        <h3 class="text-pnp-blue font-black uppercase tracking-widest text-xs mb-1">Brgy. ${name}</h3>
                                        <p class="text-[9px] text-gray-500 font-bold uppercase mb-2">Sta. Cruz, Laguna</p>
                                        <div class="flex justify-between items-center">
                                            <span class="text-[8px] text-gray-400 font-bold uppercase">Status</span>
                                            <span class="px-2 py-0.5 bg-green-100 text-green-600 rounded-full text-[7px] font-black uppercase">Secure</span>
                                        </div>
                                    </div>
                                `);
                            } catch (err) {
                                console.error('Error adding marker for barangay:', name, err);
                            }
                        }
                    }).addTo(map);
                })
                .catch(err => {
                    console.error('Error loading GeoJSON:', err);
                });
        } catch (err) {
            console.error('Error initializing map:', err);
            hideLoading();
        }
    }

    function toggleSidebar() {
        const sidebar = document.getElementById('filterSidebar');
        const toggleBtn = document.getElementById('sidebarToggle');
        
        if (sidebar.classList.contains('sidebar-hidden')) {
            sidebar.classList.remove('sidebar-hidden');
            sidebar.classList.add('sidebar-visible');
            if (toggleBtn) toggleBtn.classList.add('opacity-0', 'pointer-events-none');
        } else {
            sidebar.classList.add('sidebar-hidden');
            sidebar.classList.remove('sidebar-visible');
            if (toggleBtn) toggleBtn.classList.remove('opacity-0', 'pointer-events-none');
        }
    }

    document.addEventListener('DOMContentLoaded', initMap);
</script>

<style>
    .sidebar-hidden {
        opacity: 0;
        transform: scale(0.9) translateX(-20px);
        pointer-events: none;
    }
    .sidebar-visible {
        opacity: 1;
        transform: scale(1) translateX(0);
        pointer-events: auto;
    }

    /* Custom Scrollbar for Sidebar */
    #filterSidebar::-webkit-scrollbar {
        width: 5px;
    }
    #filterSidebar::-webkit-scrollbar-track {
        background: transparent;
    }
    #filterSidebar::-webkit-scrollbar-thumb {
        background: rgba(26, 58, 92, 0.1);
        border-radius: 10px;
        transition: all 0.3s;
    }
    #filterSidebar:hover::-webkit-scrollbar-thumb {
        background: rgba(26, 58, 92, 0.3);
    }
    .dark #filterSidebar::-webkit-scrollbar-thumb {
        background: rgba(200, 164, 21, 0.1);
    }
    .dark #filterSidebar:hover::-webkit-scrollbar-thumb {
        background: rgba(200, 164, 21, 0.3);
    }
</style>
